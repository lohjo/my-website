  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "stylelint": "^16.6.1",
    "stylelint-config-recess-order": "^5.0.1",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3"
  }
