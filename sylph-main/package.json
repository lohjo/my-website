{
  "name": "johnrayloh-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm lint && pnpm mdx:timestamps && next build",
    "start": "next start",
    "postbuild": "next-sitemap",
    "lint": "pnpm lint:style && pnpm lint:prettier && pnpm lint:biome",
    "lint:style": "stylelint \"**/*.css\" --fix",
    "lint:prettier": "prettier . --write --log-level warn",
    "lint:biome": "biome check --fix --unsafe .",
    "mdx:timestamps": "node ./scripts/update-mdx-timestamps.cjs"
  },
  "dependencies": {
    "@next/mdx": "^16.1.4",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-icons": "^1.3.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.400.0",
    "next": "16.1.4",
    "next-mdx-remote": "^5.0.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.0",
    "next-view-transitions": "^0.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reading-time-estimator": "^1.0.0",
    "rehype-pretty-code": "^0.14.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.0.0",
    "tailwind-merge": "^2.3.0",
    "unified": "^11.0.0"
